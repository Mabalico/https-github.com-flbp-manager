# Firebase Cloud Messaging
# Android package/applicationId: com.flbp.manager.suite
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
# Insert private key on one line with \n escapes, or use the PowerShell deploy script with -FcmPrivateKeyPath
FCM_PRIVATE_KEY=

# Apple Push Notification service
# iOS bundle identifier: com.flbp.manager.suite
APNS_TEAM_ID=
APNS_KEY_ID=
# Insert private key on one line with \n escapes, or use the PowerShell deploy script with -ApnsPrivateKeyPath
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=com.flbp.manager.suite
APNS_USE_SANDBOX=true
